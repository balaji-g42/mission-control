#!/usr/bin/env node

const { spawn } = require('child_process');
const path = require('path');
const fs = require('fs');

const appPath = path.dirname(__dirname);
const envPath = path.join(appPath, '.env');

// Load .env file if it exists (or use defaults for Docker)
if (fs.existsSync(envPath)) {
  const envContent = fs.readFileSync(envPath, 'utf8');
  envContent.split('\n').forEach(line => {
    const trimmed = line.trim();
    if (trimmed && !trimmed.startsWith('#')) {
      const [key, ...valueParts] = trimmed.split('=');
      if (key && valueParts.length > 0) {
        process.env[key.trim()] = valueParts.join('=').trim();
      }
    }
  });
} else {
  console.log('');
  console.log('  ℹ️  No .env file found, using defaults.');
  console.log('     Run mission-control-setup to configure.');
  console.log('');
}

// Default values
const port = process.env.PORT || 4000;
const dbPath = process.env.DATABASE_PATH || './mission-control.db';
const ttydPort = process.env.NEXT_PUBLIC_TTYD_PORT || process.env.TTYD_PORT || '3001';

// Set defaults if not configured
if (!process.env.DATABASE_PATH) process.env.DATABASE_PATH = dbPath;
if (!process.env.NEXT_PUBLIC_TTYD_PORT) process.env.NEXT_PUBLIC_TTYD_PORT = ttydPort;
if (!process.env.NODE_ENV) process.env.NODE_ENV = 'production';

console.log('');
console.log('  🚀 Starting Mission Control...');
console.log(`     http://localhost:${port}`);
console.log('');

const next = spawn('npx', ['next', 'start', '-p', port], {
  cwd: appPath,
  stdio: 'inherit',
  env: { ...process.env, NODE_ENV: 'production' },
  shell: process.platform === 'win32'
});

next.on('error', (err) => {
  console.error('Failed to start:', err.message);
  process.exit(1);
});

process.on('SIGINT', () => {
  console.log('\nShutting down...');
  next.kill('SIGINT');
});

process.on('SIGTERM', () => {
  next.kill('SIGTERM');
});