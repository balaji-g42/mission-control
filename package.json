{
  "name": "mission-control",
  "version": "2.4.0",
  "bin": {
    "mission-control": "./bin/mission-control",
    "mission-control-setup": "./bin/mission-control-setup.js"
  },
  "files": [
    "bin/",
    "src/",
    "public/",
    "next.config.mjs",
    "package.json",
    ".env.example"
  ],
  "scripts": {
    "postinstall": "node -e \"if(!process.env.CI && !process.env.MC_SILENT_INSTALL) require('child_process').execSync('node bin/mission-control-setup.js', {stdio:'inherit'})\" || true",
    "dev": "next dev --turbo -p 4000",
    "dev:next": "next dev --turbo -p 4000",
    "build": "next build",
    "start": "next start -p 4000",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:stop": "pm2 stop mission-control",
    "pm2:delete": "pm2 delete mission-control",
    "pm2:logs": "pm2 logs mission-control",
    "pm2:save": "pm2 save",
    "lint": "next lint",
    "test": "mkdir -p .tmp && rm -f .tmp/mission-control-test.db* && NODE_ENV=test DATABASE_PATH=.tmp/mission-control-test.db tsx --test src/**/*.test.ts",
    "db:seed": "tsx src/lib/db/seed.ts",
    "db:backup": "sqlite3 mission-control.db 'PRAGMA wal_checkpoint(TRUNCATE);' && cp mission-control.db mission-control.db.backup && echo 'Backed up to mission-control.db.backup'",
    "db:restore": "cp mission-control.db.backup mission-control.db && echo 'Restored from backup'",
    "db:reset": "rm -f mission-control.db mission-control.db-* && npm run db:seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@hello-pangea/dnd": "^17.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "css-tree": "^3.1.0",
    "date-fns": "^4.1.0",
    "echarts": "^6.0.0",
    "lucide-react": "^0.468.0",
    "next": "14.2.21",
    "nodemailer": "^8.0.4",
    "otplib": "^13.4.0",
    "playwright": "^1.58.1",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "source-map-js": "^1.2.1",
    "uuid": "^11.0.4",
    "ws": "^8.20.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/css-tree": "^2.3.11",
    "@types/node": "^20.17.12",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.21",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
